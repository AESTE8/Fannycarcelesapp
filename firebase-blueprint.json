{
  "entities": {
    "Lead": {
      "title": "Lead",
      "description": "A contact form submission from a potential client.",
      "type": "object",
      "properties": {
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "propertyType": { "type": "string" },
        "address": { "type": "string" },
        "surface": { "type": "number" },
        "rooms": { "type": "number" },
        "features": { "type": "array", "items": { "type": "string" } },
        "message": { "type": "string" },
        "status": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["firstName", "lastName", "email"]
    }
  },
  "firestore": {
    "/leads/{leadId}": {
      "schema": { "$ref": "#/entities/Lead" },
      "description": "Collection of contact form submissions."
    }
  }
}
